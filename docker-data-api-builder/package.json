{
  "name": "docker-data-api-builder",
  "displayName": "DAB Docker (Data API builder)",
  "description": "Build and run Data API Builder in Docker containers.",
  "publisher": "jerry-nixon",
  "version": "1.0.1",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "galleryBanner": {
    "color": "#0078d7",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JerryNixon/data-api-builder-vscode-ext.git"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "workspaceContains:**/dab-*.json",
    "workspaceContains:**/staticwebapp.database.config.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dabExtension.dockerUp",
        "title": "Docker Up",
        "category": "DAB Docker"
      },
      {
        "command": "dabExtension.dockerDown",
        "title": "Docker Down",
        "category": "DAB Docker"
      }
    ],
    "submenus": [
      {
        "id": "dabDocker.submenu",
        "label": "DAB Docker"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "dabDocker.submenu",
          "when": "(resourceFilename =~ /^dab-.*\\.json$/) || resourceFilename == 'staticwebapp.database.config.json'",
          "group": "1_dab@10"
        }
      ],
      "dabDocker.submenu": [
        {
          "command": "dabExtension.dockerUp"
        },
        {
          "command": "dabExtension.dockerDown"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.7.2",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "dab-vscode-shared": "file:../shared"
  },
  "keywords": [
    "Data API Builder",
    "dab",
    "docker",
    "container",
    "tools",
    "automation"
  ],
  "author": "Jerry Nixon",
  "license": "MIT"
}
