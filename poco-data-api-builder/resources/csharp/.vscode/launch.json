{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🖥️ Console Client",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/Gen/Client/bin/Debug/net8.0/Client.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Gen/Client",
            "console": "externalTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build"
        },
        {
            "name": "🌐 Web Explorer",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/Gen/Web/bin/Debug/net8.0/Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Gen/Web",
            "console": "internalConsole",
            "stopAtEntry": false,
            "preLaunchTask": "build",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Now listening on: http://localhost:(\\d+)",
                "uriFormat": "http://localhost:%s"
            }
        }
    ]
}
