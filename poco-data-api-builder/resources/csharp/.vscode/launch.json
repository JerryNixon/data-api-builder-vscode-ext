{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch DAB Client",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/Gen/${input:clientType}/bin/Debug/net8.0/${input:clientType}.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Gen/${input:clientType}",
            "console": "externalTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build"
        },
        {
            "name": "Launch Client (Console)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/Gen/Client/bin/Debug/net8.0/Client.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Gen/Client",
            "console": "externalTerminal",
            "stopAtEntry": false,
            "preLaunchTask": "build"
        },
        {
            "name": "Launch Web Explorer",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/Gen/Web/bin/Debug/net8.0/Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Gen/Web",
            "console": "internalConsole",
            "stopAtEntry": false,
            "preLaunchTask": "build",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bhttp://localhost:(\\d+)",
                "uriFormat": "http://localhost:%s"
            }
        }
    ],
    "inputs": [
        {
            "id": "clientType",
            "type": "pickString",
            "description": "Which client to launch?",
            "options": [
                { "label": "🖥️ Console Client", "value": "Client" },
                { "label": "🌐 Web Explorer", "value": "Web" }
            ],
            "default": "Client"
        }
    ]
}
