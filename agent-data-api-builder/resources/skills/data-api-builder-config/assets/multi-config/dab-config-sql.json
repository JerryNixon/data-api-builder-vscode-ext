{
  "data-source": {
    "database-type": "mssql",
    "connection-string": "@env('SQL_CONNECTION_STRING')"
  },
  "entities": {
    "Book": {
      "source": {
        "object": "dbo.Books",
        "type": "table"
      },
      "permissions": [
        {
          "role": "anonymous",
          "actions": [
            "read"
          ]
        }
      ]
    }
  }
}
