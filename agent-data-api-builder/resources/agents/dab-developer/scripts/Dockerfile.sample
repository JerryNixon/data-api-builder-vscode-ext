# ============================================
# SAMPLE: Dockerfile for Data API Builder
# ============================================
#
# PURPOSE: This is a REFERENCE DOCKERFILE for the DAB Developer Agent.
# It demonstrates best practices for containerizing DAB with baked configuration.
#
# USAGE:
#   docker build --build-arg DAB_VERSION=1.2.10 -t dab-api:latest .
#   docker run -p 5000:5000 -e MSSQL_CONNECTION_STRING="..." dab-api:latest
#
# OR with Azure Container Registry:
#   az acr build --registry myacr --image dab-api:v1 --build-arg DAB_VERSION=1.2.10 .
#
# ============================================

# Version is overridden at build time via --build-arg DAB_VERSION=...
# Default is set to INVALID to force explicit version specification
ARG DAB_VERSION=INVALID-SET-BY-CREATE
FROM mcr.microsoft.com/azure-databases/data-api-builder:${DAB_VERSION}

# Redeclare ARG so it's in scope again after FROM (Docker requirement)
ARG DAB_VERSION

# OCI-compliant image labels for metadata
LABEL org.opencontainers.image.title="dab-configured" \
      org.opencontainers.image.description="Data API Builder with baked configuration for Azure deployment" \
      org.opencontainers.image.version="${DAB_VERSION}" \
      org.opencontainers.image.authors="data-api-builder@microsoft.com"

# Copy configuration (DAB looks for /App/dab-config.json by default)
COPY dab-config.json /App/dab-config.json

# Make config read-only for security (fail gracefully if chmod not available)
RUN chmod 444 /App/dab-config.json || true

# ============================================
# HEALTH CHECK NOTES
# ============================================
# Container Apps provides its own health probes at the platform level.
# The /health endpoint requires runtime.health configuration in dab-config.json.
# For simplicity, we rely on Container Apps TCP port checks rather than HTTP health checks.
#
# If you need HTTP health checks, add runtime.health config to dab-config.json:
# {
#   "runtime": {
#     "host": {
#       "mode": "production"
#     },
#     "health": {
#       "enabled": true
#     }
#   }
# }
#
# Reference: https://github.com/Azure/data-api-builder/blob/main/docs/design/HealthEndpoint.md
# ============================================

# Document default port (Container Apps may infer, but this aids local runs and documentation)
EXPOSE 5000

# ============================================
# RUNTIME CONFIGURATION
# ============================================
# Connection string is supplied at runtime via environment variable.
# The dab-config.json should reference it as: "@env('MSSQL_CONNECTION_STRING')"
#
# Example connection strings:
#
# SQL Authentication:
#   MSSQL_CONNECTION_STRING="Server=tcp:myserver.database.windows.net,1433;Database=mydb;User ID=myuser;Password=mypassword;Encrypt=true;"
#
# Managed Identity (recommended for Azure):
#   MSSQL_CONNECTION_STRING="Server=tcp:myserver.database.windows.net,1433;Database=mydb;Authentication=Active Directory Managed Identity;"
#
# Azure AD Default (for local development with az login):
#   MSSQL_CONNECTION_STRING="Server=tcp:myserver.database.windows.net,1433;Database=mydb;Authentication=Active Directory Default;"
# ============================================
