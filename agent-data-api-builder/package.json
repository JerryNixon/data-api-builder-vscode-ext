{
  "name": "agent-data-api-builder",
  "displayName": "DAB Agent - Copilot Chat Participant",
  "description": "GitHub Copilot @dab chat participant for Data API Builder - create REST, GraphQL, and MCP APIs from SQL Server, Azure SQL, PostgreSQL, MySQL, and Cosmos DB without writing code.",
  "publisher": "jerry-nixon",
  "version": "1.2.8",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "galleryBanner": {
    "color": "#0078d7",
    "theme": "dark"
  },
  "homepage": "https://learn.microsoft.com/azure/data-api-builder/",
  "bugs": {
    "url": "https://github.com/JerryNixon/data-api-builder-vscode-ext/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JerryNixon/data-api-builder-vscode-ext.git"
  },
  "categories": [
    "AI",
    "Chat",
    "Data Science",
    "Other"
  ],
  "extensionDependencies": [
    "github.copilot-chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "dab.participant",
        "name": "dab",
        "fullName": "DAB Developer",
        "description": "Create REST, GraphQL, and MCP APIs from your database",
        "isSticky": true,
        "disambiguation": [
          {
            "category": "dab_setup",
            "description": "The user wants to set up Data API Builder, create APIs from a database, or generate REST/GraphQL endpoints without writing code.",
            "examples": [
              "Create a REST API from my SQL Server database",
              "Set up Data API Builder for my project",
              "Generate GraphQL endpoints from database tables",
              "Initialize DAB with my connection string",
              "Create an MCP server for my database"
            ]
          },
          {
            "category": "dab_entities",
            "description": "The user wants to add database tables, views, or stored procedures to their DAB configuration.",
            "examples": [
              "Add the Products table to DAB",
              "Expose my stored procedures as API endpoints",
              "Add all tables from my database",
              "Create an entity for the Orders view",
              "Add relationships between entities"
            ]
          },
          {
            "category": "dab_config",
            "description": "The user wants to configure DAB settings like authentication, caching, CORS, or endpoint paths.",
            "examples": [
              "Enable caching for my DAB API",
              "Configure JWT authentication for DAB",
              "Set up CORS for localhost",
              "Enable the MCP endpoint",
              "Change the REST API path"
            ]
          },
          {
            "category": "dab_run",
            "description": "The user wants to start, stop, validate, or troubleshoot Data API Builder.",
            "examples": [
              "Start the DAB server",
              "Validate my DAB configuration",
              "Why is DAB not connecting to my database",
              "Check if my DAB config is valid",
              "Run Data API Builder"
            ]
          }
        ]
      }
    ],
    "chatAgents": [
      {
        "path": "resources/agents/dab-developer.agent.md"
      }
    ],
    "chatSkills": [
      {
        "path": "./resources/skills/aspire-data-api-builder"
      },
      {
        "path": "./resources/skills/aspire-mcp-inspector"
      },
      {
        "path": "./resources/skills/aspire-sql-commander"
      },
      {
        "path": "./resources/skills/aspire-sql-projects"
      },
      {
        "path": "./resources/skills/azure-data-api-builder"
      },
      {
        "path": "./resources/skills/azure-mcp-inspector"
      },
      {
        "path": "./resources/skills/azure-sql-commander"
      },
      {
        "path": "./resources/skills/creating-agent-skills"
      },
      {
        "path": "./resources/skills/data-api-builder-auth"
      },
      {
        "path": "./resources/skills/data-api-builder-cli"
      },
      {
        "path": "./resources/skills/data-api-builder-config"
      },
      {
        "path": "./resources/skills/data-api-builder-demo"
      },
      {
        "path": "./resources/skills/data-api-builder-mcp"
      },
      {
        "path": "./resources/skills/docker-data-api-builder"
      }
    ],
    "commands": [
      {
        "command": "dab.openChat",
        "title": "Open DAB Chat",
        "category": "DAB"
      },
      {
        "command": "dab.validate",
        "title": "Validate Configuration",
        "category": "DAB"
      },
      {
        "command": "dab.start",
        "title": "Start Server",
        "category": "DAB"
      },
      {
        "command": "dab.addEntity",
        "title": "Add Entity...",
        "category": "DAB"
      },
      {
        "command": "dab.configure",
        "title": "Configure Settings...",
        "category": "DAB"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "dab.openChat"
        },
        {
          "command": "dab.validate"
        },
        {
          "command": "dab.start"
        },
        {
          "command": "dab.addEntity"
        },
        {
          "command": "dab.configure"
        }
      ],
      "explorer/context": [
        {
          "command": "dab.validate",
          "when": "resourceFilename =~ /dab-config.*\\.json$/",
          "group": "dab@1"
        },
        {
          "command": "dab.start",
          "when": "resourceFilename =~ /dab-config.*\\.json$/",
          "group": "dab@2"
        },
        {
          "command": "dab.addEntity",
          "when": "resourceFilename =~ /dab-config.*\\.json$/",
          "group": "dab@3"
        },
        {
          "command": "dab.configure",
          "when": "resourceFilename =~ /dab-config.*\\.json$/",
          "group": "dab@4"
        },
        {
          "command": "dab.openChat",
          "when": "resourceFilename =~ /dab-config.*\\.json$/",
          "group": "dab@5"
        }
      ],
      "editor/context": [
        {
          "command": "dab.validate",
          "when": "resourceFilename =~ /dab-config.*\\.json$/",
          "group": "dab@1"
        },
        {
          "command": "dab.start",
          "when": "resourceFilename =~ /dab-config.*\\.json$/",
          "group": "dab@2"
        },
        {
          "command": "dab.addEntity",
          "when": "resourceFilename =~ /dab-config.*\\.json$/",
          "group": "dab@3"
        },
        {
          "command": "dab.configure",
          "when": "resourceFilename =~ /dab-config.*\\.json$/",
          "group": "dab@4"
        },
        {
          "command": "dab.openChat",
          "when": "resourceFilename =~ /dab-config.*\\.json$/",
          "group": "dab@5"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run merge-agent-docs && npm run package",
    "merge-agent-docs": "node scripts/merge-agent-docs.js",
    "compile": "npm run merge-agent-docs && webpack",
    "watch": "npm run merge-agent-docs && webpack --watch",
    "package": "npm run merge-agent-docs && webpack --mode production --devtool hidden-source-map",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "mocha --require ts-node/register src/test/**/*.test.ts"
  },
  "files": [
    "dist/**/*",
    "images/**/*",
    "resources/**/*"
  ],
  "dependencies": {
    "dab-vscode-shared": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@types/mocha": "^10.0.9",
    "@types/node": "20.x",
    "ts-loader": "^9.5.1",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2"
  },
  "keywords": [
    "data api builder",
    "dab",
    "rest api",
    "graphql",
    "mcp",
    "model context protocol",
    "sql server",
    "azure sql",
    "postgresql",
    "mysql",
    "cosmos db",
    "copilot",
    "chat participant",
    "ai",
    "agent",
    "agentskills",
    "microsoft fabric"
  ],
  "author": "Jerry Nixon",
  "license": "MIT"
}
