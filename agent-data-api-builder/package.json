{
  "name": "agent-data-api-builder",
  "displayName": "DAB Agent Skills - Copilot Skills for Data API Builder",
  "description": "Copilot Chat skills for Data API Builder: REST, GraphQL, MCP, auth, RLS, caching, health, observability, and Azure deployment patterns for SQL Server, Azure SQL, PostgreSQL, MySQL, and Cosmos DB.",
  "publisher": "jerry-nixon",
  "version": "1.3.1",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "galleryBanner": {
    "color": "#0078d7",
    "theme": "dark"
  },
  "homepage": "https://learn.microsoft.com/azure/data-api-builder/",
  "bugs": {
    "url": "https://github.com/JerryNixon/data-api-builder-vscode-ext/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JerryNixon/data-api-builder-vscode-ext.git"
  },
  "categories": [
    "AI",
    "Chat",
    "Data Science",
    "Other"
  ],
  "extensionDependencies": [
    "github.copilot-chat"
  ],
  "contributes": {
    "chatSkills": [
      { "path": "./resources/skills/aspire-data-api-builder" },
      { "path": "./resources/skills/aspire-mcp-inspector" },
      { "path": "./resources/skills/aspire-sql-commander" },
      { "path": "./resources/skills/aspire-sql-projects" },
      { "path": "./resources/skills/azure-app-service-data-api-builder" },
      { "path": "./resources/skills/azure-data-api-builder" },
      { "path": "./resources/skills/azure-deployment-data-api-builder" },
      { "path": "./resources/skills/azure-mcp-inspector" },
      { "path": "./resources/skills/azure-sql-commander" },
      { "path": "./resources/skills/creating-agent-skills" },
      { "path": "./resources/skills/data-api-builder-auth" },
      { "path": "./resources/skills/data-api-builder-auth-mastery" },
      { "path": "./resources/skills/data-api-builder-auto-config" },
      { "path": "./resources/skills/data-api-builder-caching" },
      { "path": "./resources/skills/data-api-builder-cli" },
      { "path": "./resources/skills/data-api-builder-config" },
      { "path": "./resources/skills/data-api-builder-demo" },
      { "path": "./resources/skills/data-api-builder-graphql" },
      { "path": "./resources/skills/data-api-builder-health" },
      { "path": "./resources/skills/data-api-builder-mcp" },
      { "path": "./resources/skills/data-api-builder-mcp-mastery" },
      { "path": "./resources/skills/data-api-builder-observability" },
      { "path": "./resources/skills/data-api-builder-relationships" },
      { "path": "./resources/skills/data-api-builder-rest" },
      { "path": "./resources/skills/data-api-builder-rls-policies" },
      { "path": "./resources/skills/docker-data-api-builder" }
    ]
  },
  "scripts": {
    "compile": "echo \"agent-data-api-builder is a declarative chatSkills extension; no build step.\" && exit 0",
    "vscode:prepublish": "echo \"agent-data-api-builder ships as-is; no prepublish step.\" && exit 0"
  },
  "files": [
    "images/**/*",
    "resources/**/*"
  ],
  "keywords": [
    "data api builder",
    "dab",
    "copilot",
    "copilot skills",
    "chat skills",
    "rest api",
    "graphql",
    "mcp",
    "model context protocol",
    "sql server",
    "azure sql",
    "postgresql",
    "mysql",
    "cosmos db",
    "agent",
    "ai"
  ],
  "author": "Jerry Nixon",
  "license": "MIT"
}
