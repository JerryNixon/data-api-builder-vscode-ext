{
  "name": "visualize-api-builder",
  "displayName": "DAB Visualize (Data API Builder)",
  "description": "Visualize DAB configurations as Mermaid diagram.",
  "version": "1.2.4",
  "icon": "images/icon.png",
  "publisher": "jerry-nixon",
  "engines": {
    "vscode": "^1.75.0"
  },
  "galleryBanner": {
    "color": "#0078d7",
    "theme": "dark",
    "background": "images/dab-logo.png"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JerryNixon/data-api-builder-vscode-ext.git"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "workspaceContains:**/dab-*.json",
    "workspaceContains:**/staticwebapp.database.config.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dabExtension.visualizeDab",
        "title": "DAB Visualize",
        "category": "DAB"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "dabExtension.visualizeDab",
          "when": "(resourceFilename =~ /^dab-.*\\.json$/) || resourceFilename == 'staticwebapp.database.config.json'",
          "group": "1_dab"
        }
      ]
    },
    "extensionDependencies": [
      "bierner.markdown-mermaid"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src",
    "pretest": "npm run compile && npm run lint",
    "test": "vscode-test"
  },
  "dependencies": {
    "dab-vscode-shared": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.5.0",
    "ts-loader": "^9.5.1",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "typescript": "^5.6.3",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.18.2"
  }
}